model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  gearItemId String
  gearItem   GearItem @relation(fields: [gearItemId], references: [id])

  @@map("reviews")
}